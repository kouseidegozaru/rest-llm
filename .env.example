# ─────────────────────────────────────────────
# .env.example  →  本番では .env にコピーして使用
# ─────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DEBUG=False

# 信頼できるメンバーのIPアドレスまたはホスト名をカンマ区切りで指定
# 例: 192.168.1.10,192.168.1.11,myserver.local
ALLOWED_HOSTS=127.0.0.1,localhost

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=120

# レート制限 (requests/period: second, minute, hour, day)
THROTTLE_RATE=30/minute
